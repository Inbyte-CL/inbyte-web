{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "astro",
  "regions": ["iad1"],
  "redirects": [
    {
      "source": "/fr/parking",
      "destination": "/parking/",
      "permanent": true
    },
    {
      "source": "/fr/parking/",
      "destination": "/parking/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy/",
      "permanent": true
    },
    {
      "source": "/privacy-policy/",
      "destination": "/privacy/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "inbyte.cl"
        }
      ],
      "destination": "https://www.inbyte.cl/$1",
      "permanent": true
    }
  ],
  "git": {
    "deploymentEnabled": true
  }
}

