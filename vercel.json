{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "astro",
  "regions": ["iad1"],
  "redirects": [
    {
      "source": "/blog",
      "destination": "https://www.inbyte.cl/blog/",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "https://www.inbyte.cl/contact/",
      "permanent": true
    },
    {
      "source": "/faq",
      "destination": "https://www.inbyte.cl/faq/",
      "permanent": true
    },
    {
      "source": "/parking",
      "destination": "https://www.inbyte.cl/parking/",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "https://www.inbyte.cl/privacy/",
      "permanent": true
    },
    {
      "source": "/vending",
      "destination": "https://www.inbyte.cl/vending/",
      "permanent": true
    },
    {
      "source": "/fr/parking",
      "destination": "https://www.inbyte.cl/parking/",
      "permanent": true
    },
    {
      "source": "/fr/parking/",
      "destination": "https://www.inbyte.cl/parking/",
      "permanent": true
    },
    {
      "source": "/fr/blog",
      "destination": "https://www.inbyte.cl/blog/",
      "permanent": true
    },
    {
      "source": "/fr/blog/",
      "destination": "https://www.inbyte.cl/blog/",
      "permanent": true
    },
    {
      "source": "/fr/contact",
      "destination": "https://www.inbyte.cl/contact/",
      "permanent": true
    },
    {
      "source": "/fr/contact/",
      "destination": "https://www.inbyte.cl/contact/",
      "permanent": true
    },
    {
      "source": "/fr/faq",
      "destination": "https://www.inbyte.cl/faq/",
      "permanent": true
    },
    {
      "source": "/fr/faq/",
      "destination": "https://www.inbyte.cl/faq/",
      "permanent": true
    },
    {
      "source": "/fr/vending",
      "destination": "https://www.inbyte.cl/vending/",
      "permanent": true
    },
    {
      "source": "/fr/vending/",
      "destination": "https://www.inbyte.cl/vending/",
      "permanent": true
    },
    {
      "source": "/fr",
      "destination": "https://www.inbyte.cl/",
      "permanent": true
    },
    {
      "source": "/fr/",
      "destination": "https://www.inbyte.cl/",
      "permanent": true
    },
    {
      "source": "/fr/:path*",
      "destination": "https://www.inbyte.cl/:path*",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "https://www.inbyte.cl/privacy/",
      "permanent": true
    },
    {
      "source": "/privacy-policy/",
      "destination": "https://www.inbyte.cl/privacy/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "inbyte.cl"
        }
      ],
      "destination": "https://www.inbyte.cl/$1",
      "permanent": true
    }
  ],
  "git": {
    "deploymentEnabled": true
  }
}

